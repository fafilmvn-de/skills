      "severity": "high"
    },
    {
      "id": "php-system-get",
      "encodedPattern": "PFw/cGhwW1xzXFNdKj9zeXN0ZW1cKFwkX0dFVA==",
      "replacement": "[[REDACTED:php-system-get]]",
      "severity": "high"
    },
    {
